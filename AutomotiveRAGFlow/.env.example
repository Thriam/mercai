# OpenRouter Configuration for AutomotiveRAGFlow
# 1. Go to https://openrouter.ai
# 2. Sign up/Login
# 3. Go to Keys tab: https://openrouter.ai/keys
# 4. Create new API key (name it "AutomotiveRAGFlow")
# 5. Copy the key (starts with sk-or-v1-...)
# 6. Replace below, remove #, save as .env
APP_NAME=AutomotiveRAGFlow
# OLLAMA_URL=http://localhost:11434
# OLLAMA_MODEL=mistral:latest
OPENROUTER_API_KEY=sk-or-v1-key
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=openai/gpt-4o-mini
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
# RAW_DATA_DIR=app/data/raw
# PROCESSED_DATA_DIR=app/data/processed
# VECTOR_DB_DIR=app/data/vector_db
VECTOR_STORE_FILE=vectors.json
CHUNK_SIZE=500
CHUNK_OVERLAP=50
TOP_K=5
